# rx-browser-bridge — shared environment template.
# Copy to .env and edit. .env is gitignored.
#
# All three components (relay, mcp, docker-compose) load this same file:
#   - relay:  `npm -w relay run dev` / `npm -w relay start` via node --env-file-if-exists
#   - mcp:    launched by Claude Code via .mcp.json, same flag
#   - docker: relay/docker-compose.yml has `env_file: ../.env`

# --- Relay listen address ---
PORT=3000
HOST=0.0.0.0

# --- Shared secrets (relay enforces; clients must match) ---
# POSTER_TOKEN: MCP → relay HTTP (/enqueue, /poll, /browsers)
# PULLER_TOKEN: extension → relay WS
# Generate with: openssl rand -hex 32
# Rotate before exposing the relay beyond localhost.
POSTER_TOKEN=replace-me-poster
PULLER_TOKEN=replace-me-puller

# --- Relay storage ---
# Host-mode path is relative to relay cwd. Compose mounts ./data → /data.
DATA_DIR=./data

# --- MCP client config ---
RELAY_URL=http://localhost:3000
# Optional: default browser id when MCP tools are called without `target`.
DEFAULT_TARGET=
