{
  "name": "@rx-browser-bridge/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist/server.js",
    "dev": "node --env-file-if-exists=../.env --import tsx src/server.ts",
    "start": "node --env-file-if-exists=../.env dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
